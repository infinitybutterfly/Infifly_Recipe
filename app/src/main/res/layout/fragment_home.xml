        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/recyclerviewPopularRecipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView5"/>
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutDots"
            android:layout_width="match_parent"
            android:layout_height="14dp"
        android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:layout_marginBottom="19dp"
        android:background="@color/fully_transparent"
            app:tabBackground="@drawable/tab_pager_selector"
            app:tabGravity="center"
            app:tabMinWidth="16dp"
            app:tabMaxWidth="16dp"
            app:tabRippleColor="@null"
            app:tabIndicatorHeight="0dp"
        app:layout_constraintStart_toStartOf="@id/recyclerviewPopularRecipe"
        app:layout_constraintEnd_toEndOf="@id/recyclerviewPopularRecipe"
            app:layout_constraintBottom_toBottomOf="@id/recyclerviewPopularRecipe" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Recipe For You"
            android:textStyle="bold"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="@+id/searchBar"
            app:layout_constraintTop_toBottomOf="@id/recyclerviewPopularRecipe" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerviewRecipeForYou"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="9dp"
            android:paddingBottom="250dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="10dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            tools:listitem="@layout/recipe_for_you_layout"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView6"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:id="@+id/popular_recipe_layout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="16dp"
    android:layout_margin="5dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <ImageView
        android:id="@+id/popular_recipe_dish_img"
        android:layout_width="0dp"
        android:layout_height="280dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/demo_img"
        android:scaleType="centerCrop"/>

    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/black_shade"
        app:layout_constraintBottom_toBottomOf="@id/popular_recipe_dish_img"
        app:layout_constraintEnd_toEndOf="@id/popular_recipe_dish_img"
        app:layout_constraintStart_toStartOf="@id/popular_recipe_dish_img"
        app:layout_constraintTop_toTopOf="@id/popular_recipe_dish_img" />


    <TextView
        android:id="@+id/popular_recipe_country_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Country Name"
        android:textSize="16sp"
        android:padding="5dp"
        android:textColor="@color/white"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="22dp"
        app:layout_constraintBottom_toBottomOf="@+id/popular_recipe_dish_img"
        app:layout_constraintStart_toStartOf="@+id/popular_recipe_dish_img" />
    <TextView
        android:id="@+id/idmealnumberpopular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="ID Meal"
        android:textSize="0sp"
        android:visibility="gone"
        android:padding="5dp"
        android:textColor="@color/white"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="parent" />

    <TextView
        android:id="@+id/popular_recipe_dish_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dish Name"
        android:padding="5dp"
        android:gravity="start"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:layout_marginStart="15dp"
        android:textColor="@color/white"
        android:textSize="25sp"
        app:layout_constraintBottom_toTopOf="@+id/popular_recipe_country_name"
        app:layout_constraintStart_toStartOf="@id/popular_recipe_dish_img"
        app:layout_constraintEnd_toEndOf="@id/popular_recipe_dish_img"/>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Premium Feature 🌟"
    android:textSize="24sp"
    android:textStyle="bold"
    android:textColor="@color/black"
    android:gravity="center"
    android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You are a free tier user. Upgrade to Premium to manage your uploaded recipes, edit your creations, and share them with the world!"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_subscribe_my_recipe"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Upgrade to Premium"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_maybe_later_my_recipe"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Maybe Later"
        android:textColor="@android:color/darker_gray"/>

</LinearLayout>
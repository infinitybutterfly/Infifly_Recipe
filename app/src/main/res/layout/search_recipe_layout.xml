<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_margin="7dp">

        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:id="@+id/search_img_card"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:cardCornerRadius="16dp">

            <ImageView
                android:id="@+id/search_recipe_dish_img"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:layout_constraintEnd_toEndOf="@id/search_img_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/demo_img"
                android:scaleType="centerCrop"/>

            <ImageView
                android:id="@+id/premium_icon_search_result"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/premium"
                app:cardElevation="0dp"
                android:layout_marginTop="15dp"
                android:layout_marginStart="15dp"
                android:padding="5dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

        </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/search_recipe_country_name"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="Country Name"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@id/search_recipe_dish_name"
        app:layout_constraintStart_toStartOf="@id/search_recipe_dish_name"
        app:layout_constraintTop_toBottomOf="@id/search_recipe_dish_name" />

    <TextView
        android:id="@+id/search_recipe_dish_name"
        android:layout_width="150dp"
        android:layout_height="0dp"
        android:layout_marginTop="7dp"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:paddingTop="5dp"
        android:text="Dish Namehhhhhhhhhhhh"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/search_img_card"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/idmealnumbersearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dish Name"
            android:paddingTop="5dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textSize="0sp"
            android:layout_margin="20dp"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>